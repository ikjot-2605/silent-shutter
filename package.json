{
  "name": "silent-shutter",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "Silent Shutter — Photography portfolio by Ikjot Dhody",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "lint": "tsc --noEmit",
    "scan": "node tools/scan-images.mjs",
    "predeploy": "npm run scan && npm run build",
    "deploy": "gh-pages -d dist",
    "dashboard": "node tools/image-dashboard.mjs"
  },
  "dependencies": {
    "framer-motion": "^11.15.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^7.13.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "gh-pages": "^6.3.0",
    "typescript": "^5.6.3",
    "vite": "^6.0.0"
  }
}
